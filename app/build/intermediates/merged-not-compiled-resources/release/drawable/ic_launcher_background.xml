<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#223B1F"
                android:centerColor="#2F512A"
                android:endColor="#1A2816" />
        </shape>
    </item>

    <item android:left="8dp" android:top="10dp" android:right="64dp" android:bottom="70dp">
        <shape android:shape="oval">
            <solid android:color="#335C3A" />
        </shape>
    </item>
    <item android:left="56dp" android:top="20dp" android:right="14dp" android:bottom="62dp">
        <shape android:shape="oval">
            <solid android:color="#2B4724" />
        </shape>
    </item>
    <item android:left="20dp" android:top="56dp" android:right="48dp" android:bottom="26dp">
        <shape android:shape="oval">
            <solid android:color="#3E6442" />
        </shape>
    </item>
    <item android:left="62dp" android:top="62dp" android:right="10dp" android:bottom="14dp">
        <shape android:shape="oval">
            <solid android:color="#27411F" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="120dp"
                android:centerX="0.5"
                android:centerY="0.4"
                android:startColor="#15000000"
                android:endColor="#77000000" />
        </shape>
    </item>
</layer-list>
