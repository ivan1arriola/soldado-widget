<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Frame 3: Sueño/Cansancio (Ojos cerrados, más bajo) -->

    <!-- Sombra del suelo -->
    <item android:top="64dp" android:left="20dp" android:right="20dp" android:bottom="2dp">
        <shape android:shape="oval"><solid android:color="#20000000" /></shape>
    </item>

    <!-- Cuerpo (Un poco más bajo) -->
    <item android:top="35dp" android:left="18dp" android:right="18dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#78866B" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Cabeza (Un poco inclinada) -->
    <item android:top="11dp" android:left="16dp" android:right="16dp" android:bottom="27dp">
        <shape android:shape="oval"><solid android:color="#FFDBAC" /></shape>
    </item>

    <!-- Casco -->
    <item android:top="7dp" android:left="15dp" android:right="15dp" android:bottom="43dp">
        <shape android:shape="oval"><solid android:color="#556B2F" /></shape>
    </item>

    <!-- Ojos (Lineas = Dormido) -->
    <item android:top="28dp" android:left="28dp" android:right="38dp" android:bottom="35dp">
        <shape android:shape="rectangle"><solid android:color="#212121" /><corners android:radius="1dp"/></shape>
    </item>
    <item android:top="28dp" android:left="38dp" android:right="28dp" android:bottom="35dp">
        <shape android:shape="rectangle"><solid android:color="#212121" /><corners android:radius="1dp"/></shape>
    </item>

    <!-- Burbuja de sueño Zzz (Minimalista) -->
    <item android:top="5dp" android:left="45dp" android:right="10dp" android:bottom="55dp">
        <shape android:shape="oval"><solid android:color="#A0FFFFFF" /></shape>
    </item>
    <item android:top="15dp" android:left="52dp" android:right="5dp" android:bottom="45dp">
        <shape android:shape="oval"><solid android:color="#80FFFFFF" /></shape>
    </item>

    <!-- Brazos caídos -->
    <item android:top="43dp" android:left="12dp" android:right="52dp" android:bottom="13dp">
        <shape android:shape="rectangle"><solid android:color="#78866B" /><corners android:radius="8dp"/></shape>
    </item>
    <item android:top="43dp" android:left="52dp" android:right="12dp" android:bottom="13dp">
        <shape android:shape="rectangle"><solid android:color="#78866B" /><corners android:radius="8dp"/></shape>
    </item>
</layer-list>
