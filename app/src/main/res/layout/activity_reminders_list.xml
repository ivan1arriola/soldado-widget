<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/remindersListRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B2412"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/app_container_bg"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/remindersListTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mis Recordatorios"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/remindersListStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Cargando..."
            android:textColor="#BBC5B4"
            android:textSize="14sp" />

        <ProgressBar
            android:id="@+id/remindersListProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/remindersListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:spacing="8dp" />
        </ScrollView>

        <Button
            android:id="@+id/btnRefreshReminders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Actualizar" />

        <Button
            android:id="@+id/btnBackReminders"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="VOLVER"
            android:textColor="#A4B09A" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
