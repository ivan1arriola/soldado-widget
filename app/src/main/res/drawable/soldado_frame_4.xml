<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Frame 4: Parpadeo (Ojos como líneas) -->
    <!-- Sombra del suelo -->
    <item android:top="64dp" android:left="20dp" android:right="20dp" android:bottom="2dp">
        <shape android:shape="oval"><solid android:color="#20000000" /></shape>
    </item>

    <!-- Cuerpo -->
    <item android:top="30dp" android:left="18dp" android:right="18dp" android:bottom="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#78866B" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Cinturón -->
    <item android:top="50dp" android:left="18dp" android:right="18dp" android:bottom="22dp">
        <shape android:shape="rectangle"><solid android:color="#3E2723" /></shape>
    </item>
    <item android:top="49dp" android:left="34dp" android:right="34dp" android:bottom="21dp">
        <shape android:shape="rectangle"><solid android:color="#FFD700" /><corners android:radius="1dp" /></shape>
    </item>

    <!-- Cabeza -->
    <item android:top="6dp" android:left="16dp" android:right="16dp" android:bottom="32dp">
        <shape android:shape="oval"><solid android:color="#FFDBAC" /></shape>
    </item>

    <!-- Casco -->
    <item android:top="2dp" android:left="15dp" android:right="15dp" android:bottom="48dp">
        <shape android:shape="oval"><solid android:color="#556B2F" /></shape>
    </item>

    <!-- Ojos (Parpadeando - líneas horizontales de 16x5dp) -->
    <item android:top="25dp" android:left="27dp" android:right="37dp" android:bottom="30dp">
        <shape android:shape="rectangle"><solid android:color="#212121" /><corners android:radius="1dp"/></shape>
    </item>
    <item android:top="25dp" android:left="37dp" android:right="27dp" android:bottom="30dp">
        <shape android:shape="rectangle"><solid android:color="#212121" /><corners android:radius="1dp"/></shape>
    </item>

    <!-- Brazos pequeños -->
    <item android:top="38dp" android:left="10dp" android:right="54dp" android:bottom="18dp">
        <shape android:shape="rectangle"><solid android:color="#78866B" /><corners android:radius="8dp"/></shape>
    </item>
    <item android:top="38dp" android:left="54dp" android:right="10dp" android:bottom="18dp">
        <shape android:shape="rectangle"><solid android:color="#78866B" /><corners android:radius="8dp"/></shape>
    </item>
</layer-list>