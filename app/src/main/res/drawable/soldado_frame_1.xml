<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Frame 1: Movimiento ligero (Brazos un poco más arriba) -->

    <!-- Sombra del suelo -->
    <item android:top="64dp" android:left="20dp" android:right="20dp" android:bottom="2dp">
        <shape android:shape="oval"><solid android:color="#20000000" /></shape>
    </item>

    <!-- Cuerpo -->
    <item android:top="28dp" android:left="18dp" android:right="18dp" android:bottom="10dp">
        <shape android:shape="rectangle">
            <solid android:color="#78866B" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Detalle: Cinturón Militar -->
    <item android:top="48dp" android:left="18dp" android:right="18dp" android:bottom="24dp">
        <shape android:shape="rectangle">
            <solid android:color="#3E2723" />
        </shape>
    </item>
    <item android:top="47dp" android:left="32dp" android:right="32dp" android:bottom="23dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFD700" />
            <corners android:radius="1dp" />
        </shape>
    </item>

    <!-- Cabeza -->
    <item android:top="4dp" android:left="16dp" android:right="16dp" android:bottom="34dp">
        <shape android:shape="oval"><solid android:color="#FFDBAC" /></shape>
    </item>

    <!-- Casco -->
    <item android:top="0dp" android:left="15dp" android:right="15dp" android:bottom="50dp">
        <shape android:shape="oval"><solid android:color="#556B2F" /></shape>
    </item>
    <item android:top="12dp" android:left="15dp" android:right="15dp" android:bottom="54dp">
        <shape android:shape="rectangle"><solid android:color="#556B2F" /><corners android:bottomLeftRadius="4dp" android:bottomRightRadius="4dp"/></shape>
    </item>

    <!-- Ojos (Normalizados para evitar deformación) -->
    <item android:top="20dp" android:left="27dp" android:right="37dp" android:bottom="38dp">
        <shape android:shape="oval"><solid android:color="#212121" /></shape>
    </item>
    <item android:top="20dp" android:left="37dp" android:right="27dp" android:bottom="38dp">
        <shape android:shape="oval"><solid android:color="#212121" /></shape>
    </item>

    <!-- Pupilas -->
    <item android:top="22dp" android:left="29dp" android:right="39dp" android:bottom="40dp">
        <shape android:shape="oval"><solid android:color="#3E2723" /></shape>
    </item>
    <item android:top="22dp" android:left="39dp" android:right="29dp" android:bottom="40dp">
        <shape android:shape="oval"><solid android:color="#3E2723" /></shape>
    </item>

    <!-- Brillos -->
    <item android:top="21dp" android:left="29dp" android:right="41dp" android:bottom="42dp">
        <shape android:shape="oval"><solid android:color="#FFFFFF" /></shape>
    </item>
    <item android:top="21dp" android:left="39dp" android:right="31dp" android:bottom="42dp">
        <shape android:shape="oval"><solid android:color="#FFFFFF" /></shape>
    </item>

    <!-- Mejillas sonrosadas -->
    <item android:top="26dp" android:left="24dp" android:right="42dp" android:bottom="40dp">
        <shape android:shape="oval"><solid android:color="#40FF8080" /></shape>
    </item>
    <item android:top="26dp" android:left="42dp" android:right="24dp" android:bottom="40dp">
        <shape android:shape="oval"><solid android:color="#40FF8080" /></shape>
    </item>

    <!-- Brazos un poco más arriba (Dando vida) -->
    <item android:top="34dp" android:left="8dp" android:right="56dp" android:bottom="22dp">
        <shape android:shape="rectangle"><solid android:color="#78866B" /><corners android:radius="8dp"/></shape>
    </item>
    <item android:top="34dp" android:left="56dp" android:right="8dp" android:bottom="22dp">
        <shape android:shape="rectangle"><solid android:color="#78866B" /><corners android:radius="8dp"/></shape>
    </item>
</layer-list>
