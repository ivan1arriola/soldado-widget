<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="64dp"
    android:height="64dp">
    <!-- Frame 1: Movimiento ligero (Brazos un poco más arriba) -->
    <!-- Sombra del suelo -->
    <item android:top="58dp" android:left="20dp" android:right="20dp" android:bottom="2dp">
        <shape android:shape="oval"><solid android:color="#20000000" /></shape>
    </item>

    <!-- Cuerpo -->
    <item android:top="26dp" android:left="18dp" android:right="18dp" android:bottom="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#78866B" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Detalle: Cinturón Militar -->
    <item android:top="43dp" android:left="18dp" android:right="18dp" android:bottom="16dp">
        <shape android:shape="rectangle">
            <solid android:color="#3E2723" />
        </shape>
    </item>

    <!-- Cabeza -->
    <item android:top="4dp" android:left="16dp" android:right="16dp" android:bottom="30dp">
        <shape android:shape="oval"><solid android:color="#FFDBAC" /></shape>
    </item>

    <!-- Casco -->
    <item android:top="0dp" android:left="15dp" android:right="15dp" android:bottom="44dp">
        <shape android:shape="oval"><solid android:color="#556B2F" /></shape>
    </item>

    <!-- Ojos -->
    <item android:top="18dp" android:left="25dp" android:right="35dp" android:bottom="34dp">
        <shape android:shape="oval"><solid android:color="#212121" /></shape>
    </item>
    <item android:top="18dp" android:left="35dp" android:right="25dp" android:bottom="34dp">
        <shape android:shape="oval"><solid android:color="#212121" /></shape>
    </item>

    <!-- Brazos un poco más arriba -->
    <item android:top="32dp" android:left="8dp" android:right="52dp" android:bottom="22dp">
        <shape android:shape="rectangle"><solid android:color="#78866B" /><corners android:radius="8dp"/></shape>
    </item>
    <item android:top="32dp" android:left="52dp" android:right="8dp" android:bottom="22dp">
        <shape android:shape="rectangle"><solid android:color="#78866B" /><corners android:radius="8dp"/></shape>
    </item>
</layer-list>
